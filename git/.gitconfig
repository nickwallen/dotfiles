[user]
	email = nick.allen@datadoghq.com
	name = Nick Allen
	signingKey = key::ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIL57rla+OuM/VfHuPuedCUNXlLxIFQ+Jdfhd74WABRRx
[url "git@github.com:"]
	insteadOf = https://github.com/
	insteadOf = git://github.com/
[push]
	autoSetupRemote = true
[alias]
	ffmain = !git fetch origin main && git merge --ff-only FETCH_HEAD
[core]
	hooksPath = /usr/local/dd/global_hooks
	fsmonitor = true
[init]
	defaultBranch = main
[feature]
	manyFiles = true
[index]
	threads = true
[maintenance]
	repo = ~/go/src/github.com/DataDog/dd-source
	repo = /private/tmp/dd-source
	repo = /private/tmp/dd-source-search
[include]
	path = ~/.config/gitsign/gitconfig
[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[dd-gitsign]
	username = nickwallen
[commit]
	gpgSign = true
[tag]
	gpgSign = true
[gpg]
	format = ssh
[gpg "ssh"]
	program = dd-gitsign
	allowedSignersFile = ~/.config/gitsign/allowed-signers
